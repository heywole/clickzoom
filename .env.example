# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clickzoom

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_32_characters

# ─── Google OAuth ─────────────────────────────────────────
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Email ────────────────────────────────────────────────
# Use Gmail with App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=your_16_char_app_password

# ─── Storage (Cloudflare R2) ──────────────────────────────
# Get from: https://dash.cloudflare.com → R2
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET=clickzoom-storage
CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ─── Self-Hosted Services ─────────────────────────────────
# Run with: docker compose up
COQUI_TTS_URL=http://localhost:5002
WHISPER_URL=http://localhost:9000
LIBRETRANSLATE_URL=http://localhost:5003

# ─── Web3 Wallet ──────────────────────────────────────────
# Platform wallet for automated DeFi tutorial capture only
CLICKZOOM_WALLET_PRIVATE_KEY=your_wallet_private_key_here
CLICKZOOM_WALLET_MAX_TX_AMOUNT=0.01
CLICKZOOM_WALLET_DAILY_LIMIT=0.1
CLICKZOOM_WALLET_PER_TUTORIAL_LIMIT=0.02

# ─── Error Tracking (Sentry) ──────────────────────────────
# Free tier: https://sentry.io → Create account → New Project → Node.js
# Leave blank to disable error tracking
SENTRY_DSN=

# ─── Client URL ───────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Client-side env vars (prefix with REACT_APP_) ────────
# Copy these to client/.env too if needed
REACT_APP_API_URL=http://localhost:5000/api
# Free tier: https://sentry.io → New Project → React
REACT_APP_SENTRY_DSN=
